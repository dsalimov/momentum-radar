# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# Data Provider API Keys (optional – yfinance is free and needs no key)
POLYGON_API_KEY=your_polygon_api_key_here
ALPACA_API_KEY=your_alpaca_api_key_here
ALPACA_SECRET_KEY=your_alpaca_secret_key_here

# Application Settings
LOG_LEVEL=INFO
DATA_PROVIDER=yfinance

# Signal Thresholds
VOLUME_SPIKE_STRONG=2.0
VOLUME_SPIKE_MODERATE=1.5
DAILY_VOLUME_RATIO=1.5
INTRADAY_VOLUME_RATIO=3.0
RVOL_MODERATE=2.0
RVOL_STRONG=3.0
ATR_RATIO_MODERATE=1.5
ATR_RATIO_STRONG=2.0
SHORT_INTEREST_MIN=0.15
DAYS_TO_COVER_MIN=3
FLOAT_MAX=200000000
OPTIONS_VOLUME_RATIO=3.0

# Score Thresholds
SCORE_WATCHLIST=4
SCORE_HIGH_PRIORITY=6
SCORE_STRONG_MOMENTUM=8
SCORE_ALERT_MINIMUM=5

# Scan Settings
SCAN_INTERVAL=60
ALERT_COOLDOWN=600

# Universe Filters
MIN_PRICE=5.0
MIN_AVG_VOLUME=1000000
UNIVERSE_SIZE=1000

# Market Hours (EST)
MARKET_OPEN=09:35
MARKET_CLOSE=15:45
LUNCH_START=12:00
LUNCH_END=13:30
